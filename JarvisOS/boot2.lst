     1                                  [BITS 16]
     2                                  [ORG 0x7E00]
     3                                  
     4                                  start:
     5 00000000 FA                          cli
     6                                  
     7 00000001 31C0                        xor ax, ax
     8 00000003 8ED8                        mov ds, ax
     9 00000005 8EC0                        mov es, ax
    10 00000007 8ED0                        mov ss, ax
    11 00000009 BC007C                      mov sp, 0x7C00
    12                                  
    13                                      ; ------------------------
    14                                      ; LOAD KERNEL (REAL MODE)
    15                                      ; ------------------------
    16                                  
    17 0000000C BB0010                      mov bx, 0x1000     ; load to 0x10000
    18 0000000F 8EC3                        mov es, bx
    19 00000011 31DB                        xor bx, bx
    20                                  
    21 00000013 B402                        mov ah, 0x02
    22 00000015 B020                        mov al, 32         ; kernel size (adjust later)
    23 00000017 B500                        mov ch, 0
    24 00000019 B106                        mov cl, 6          ; kernel starts after stage2
    25 0000001B B600                        mov dh, 0
    26 0000001D B200                        mov dl, 0
    27                                  
    28                                  .load:
    29 0000001F CD13                        int 0x13
    30 00000021 72FE                        jc $
    31                                  
    32 00000023 81C30002                    add bx, 512
    33 00000027 FEC1                        inc cl
    34 00000029 FEC8                        dec al
    35 0000002B 75F2                        jnz .load
    36                                  
    37                                      ; ------------------------
    38                                      ; ENTER PROTECTED MODE
    39                                      ; ------------------------
    40                                  
    41 0000002D 0F0116[7100]                lgdt [gdt_descriptor]
    42                                  
    43 00000032 0F20C0                      mov eax, cr0
    44 00000035 6683C801                    or eax, 1
    45 00000039 0F22C0                      mov cr0, eax
    46                                  
    47 0000003C EA[4100]0800                jmp 0x08:pmode
    48                                  
    49                                  [BITS 32]
    50                                  pmode:
    51 00000041 66B81000                    mov ax, 0x10
    52 00000045 8ED8                        mov ds, ax
    53 00000047 8EC0                        mov es, ax
    54 00000049 8ED0                        mov ss, ax
    55 0000004B 8EE0                        mov fs, ax
    56 0000004D 8EE8                        mov gs, ax
    57                                  
    58 0000004F BC00000900                  mov esp, 0x90000
    59                                  
    60                                      ; IMPORTANT: jump to kernel ENTRY, not raw address
    61 00000054 E9(00000100)                jmp 0x10000
    62                                  
    63                                  %include "src/boot/gdt.asm"
     1                              <1> ; Global Descriptor Table
     2                              <1> gdt_start:
     3                              <1>     ; null descriptor
     4 00000059 00000000            <1>     dd 0x0          ; 4 bytes
     5 0000005D 00000000            <1>     dd 0x0
     6                              <1> 
     7                              <1>     ; code descriptor: base=0x0, limit=0xFFFFF, 4KB granularity, 32-bit, code, readable
     8 00000061 FFFF                <1>     dw 0xFFFF       ; limit (low)
     9 00000063 0000                <1>     dw 0x0          ; base (low)
    10 00000065 00                  <1>     db 0x0          ; base (middle)
    11 00000066 9A                  <1>     db 10011010b    ; access (present, ring0, code, executable, readable)
    12 00000067 CF                  <1>     db 11001111b    ; flags (granularity, 32-bit) and limit (high)
    13 00000068 00                  <1>     db 0x0          ; base (high)
    14                              <1> 
    15                              <1>     ; data descriptor: base=0x0, limit=0xFFFFF, 4KB granularity, 32-bit, data, writable
    16 00000069 FFFF                <1>     dw 0xFFFF       ; limit (low)
    17 0000006B 0000                <1>     dw 0x0          ; base (low)
    18 0000006D 00                  <1>     db 0x0          ; base (middle)
    19 0000006E 92                  <1>     db 10010010b    ; access (present, ring0, data, expand-up, writable)
    20 0000006F CF                  <1>     db 11001111b    ; flags (granularity, 32-bit) and limit (high)
    21 00000070 00                  <1>     db 0x0          ; base (high)
    22                              <1> 
    23                              <1> gdt_end:
    24                              <1> 
    25                              <1> gdt_descriptor:
    26 00000071 1700                <1>     dw gdt_end - gdt_start - 1  ; size of GDT
    27 00000073 [59000000]          <1>     dd gdt_start                ; address of GDT
